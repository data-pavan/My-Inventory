{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "A category for items",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the category" },
        "description": { "type": "string", "description": "A description of the category" }
      },
      "required": ["name"]
    },
    "Item": {
      "title": "Item",
      "description": "An inventory item",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the item" },
        "categoryId": { "type": "string", "description": "The ID of the category" },
        "unit": { "type": "string", "description": "The unit of measurement (pcs, kg, etc.)" },
        "minStock": { "type": "number", "description": "Minimum stock level for alerts" },
        "currentStock": { "type": "number", "description": "Current stock level (auto-calculated)" },
        "scheduledStock": { "type": "number", "description": "Stock scheduled for dispatch" }
      },
      "required": ["name", "categoryId", "unit", "minStock", "currentStock"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A stock movement transaction",
      "type": "object",
      "properties": {
        "voucherNo": { "type": "string", "description": "Auto-generated voucher number" },
        "date": { "type": "string", "format": "date-time", "description": "Date of transaction" },
        "type": { "type": "string", "enum": ["IN", "OUT", "SCHEDULED"], "description": "Transaction type" },
        "itemId": { "type": "string", "description": "The ID of the item" },
        "quantity": { "type": "number", "description": "Quantity moved" },
        "sourceDestination": { "type": "string", "description": "Supplier or Destination" },
        "location": { "type": "string", "description": "Storage location" },
        "totalBoxes": { "type": "number", "description": "Total number of boxes" },
        "createdBy": { "type": "string", "description": "User ID who created the transaction" },
        "creatorEmail": { "type": "string", "description": "Email of the creator" },
        "creatorRole": { "type": "string", "description": "Role of the creator" },
        "fromScheduled": { "type": "boolean", "description": "Whether to dispatch from scheduled stock" }
      },
      "required": ["voucherNo", "date", "type", "itemId", "quantity", "createdBy", "creatorEmail", "creatorRole"]
    },
    "User": {
      "title": "User",
      "description": "Application user",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "User email" },
        "role": { "type": "string", "enum": ["admin", "staff"], "description": "User role" }
      },
      "required": ["email", "role"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A sales lead",
      "type": "object",
      "properties": {
        "leadDate": { "type": "string", "description": "Date the lead was generated" },
        "salespersonName": { "type": "string", "description": "Name of the salesperson" },
        "leadSource": { "type": "string", "description": "Source of the lead" },
        "billingName": { "type": "string", "description": "Name of the billing entity" },
        "phoneNumber": { "type": "string", "description": "Contact phone number" },
        "cityLocation": { "type": "string", "description": "City or location" },
        "sport": { "type": "string", "description": "Sport category" },
        "productInterestedIn": { "type": "string", "description": "Product of interest" },
        "approxArea": { "type": "number", "description": "Approximate area" },
        "estProjectValue": { "type": "number", "description": "Estimated project value" },
        "leadStatus": { "type": "string", "enum": ["New", "Contacted", "Quote Sent", "Negotiation", "Won", "Lost"], "description": "Current status of the lead" },
        "nextFollowUp": { "type": "string", "description": "Next follow-up date" },
        "lastRemark": { "type": "string", "description": "Last remark or comment" },
        "convertedToProject": { "type": "string", "enum": ["Yes", "No"], "description": "Whether converted to project" },
        "projectId": { "type": "string", "description": "Associated Project ID" },
        "month": { "type": "string", "description": "Month of the lead" },
        "createdAt": { "type": "string", "description": "Timestamp of creation" }
      },
      "required": ["leadDate", "salespersonName", "leadStatus", "convertedToProject"]
    }
  },
  "firestore": {
    "/categories/{categoryId}": { "schema": "Category", "description": "Collection of categories" },
    "/items/{itemId}": { "schema": "Item", "description": "Collection of items" },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Collection of transactions" },
    "/users/{userId}": { "schema": "User", "description": "Collection of users" },
    "/leads/{leadId}": { "schema": "Lead", "description": "Collection of sales leads" }
  }
}
